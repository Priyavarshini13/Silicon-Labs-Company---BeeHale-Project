# Silicon Labs Project Configuration Tools: slcp, v0, Component selection file.
project_name: si7021
label: si7021
description: |
  This application demonstrates how to use the I2C interface on the Si91x SoC device utilizing blocking APIs.
category: example|peripheral
package: platform
quality: production
readme:
- {path: readme.md}
- {path: readme.md}
source:
- {path: app.c}
- {path: i2c_follower_example.c}
include:
- path: .
  file_list:
  - {path: app.h}
  - {path: i2c_follower_example.h}
sdk: {id: simplicity_sdk, version: 2025.6.2}
toolchain_settings:
- {value: -Wall -Werror, option: gcc_compiler_option}
component:
- {from: wiseconnect3_sdk, id: SIWG917M111MGTBA}
- {from: wiseconnect3_sdk, id: brd2605a}
- instance: [i2c2]
  from: wiseconnect3_sdk
  id: i2c_instance
- {from: wiseconnect3_sdk, id: i2c_ulp_component}
- {from: wiseconnect3_sdk, id: si91x_memory_default_config}
- {from: wiseconnect3_sdk, id: sl_clock_manager}
- {from: wiseconnect3_sdk, id: sl_dma}
- {from: wiseconnect3_sdk, id: sl_gpio_peripheral}
- {from: wiseconnect3_sdk, id: sl_i2c}
- {from: wiseconnect3_sdk, id: sl_power_manager}
- {from: wiseconnect3_sdk, id: syscalls}
- {id: sl_main}
- {id: status}
other_file:
- {path: resources/readme/setupdiagram.png}
- {path: resources/readme/image506d.png}
- {path: resources/readme/image506e.png}
- {path: resources/uc_screen/i2c_uc_screen.png}
- {path: resources/readme/output.png}
configuration:
- {name: SL_I2C_I2C2_MODE, value: SL_I2C_FOLLOWER_MODE}
- {name: SL_I2C_I2C1_MODE, value: SL_I2C_FOLLOWER_MODE}
- {name: SL_I2C_I2C0_MODE, value: SL_I2C_FOLLOWER_MODE}
ui_hints:
  highlight:
  - {path: readme.md, focus: true}
sdk_extension:
- {id: wiseconnect3_sdk, version: 3.5.2}
post_build:
- {path: si7021.slpb}

